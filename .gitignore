!models/dino_finetuned.nemo

# --- LOG E TEMP (Generati da NeMo e PyTorch Lightning) ---
lightning_logs/
nemo_experiments/
*.log
*.wav
*.mp3
temp_*

# --- CONFIG (Opzionale) ---
